NAME Time Crisis 4

# Time Crisis 4 Mapping File for Namco System Super 256
# Author: dazzaXx
#
# Time Crisis 4 is a two-player light gun game that runs on Namco System Super 256.
# It uses the Namco V329 IO board (2 gun channels) for gun position input.
#
# For use with Wii Remotes:
# - Configure two Wii Remotes over Bluetooth
# - Player 1 gun position is read from ANALOGUE_1 (X) and ANALOGUE_2 (Y)
# - Player 2 gun position is read from ANALOGUE_3 (X) and ANALOGUE_4 (Y)
# - The pedal/cover button maps to CONTROLLER_BUTTON_START on each controller

INCLUDE generic-shooting

# Emulate the Namco V329 IO board used in Time Crisis 4 on System 256
EMULATE namco-v329

# Pedal / cover buttons (hide mechanic) - one per player
CONTROLLER_BUTTON_START CONTROLLER_1 BUTTON_3 PLAYER_1
CONTROLLER_BUTTON_START CONTROLLER_2 BUTTON_3 PLAYER_2

# Actual Gun Trigger (Time Crisis 4's Gun Trigger for some reason is BUTTON_LEFT)
CONTROLLER_BUTTON_A CONTROLLER_1 BUTTON_LEFT PLAYER_1

# Screen-out signal - KEY_O fires CONTROLLER_BUTTON_B when the Wiimote IR goes
# off-screen. BUTTON_RIGHT is the off-screen switch that Time Crisis 4 monitors
# on the V329 IO board.
CONTROLLER_BUTTON_B CONTROLLER_1 BUTTON_RIGHT PLAYER_1
CONTROLLER_BUTTON_B CONTROLLER_2 BUTTON_RIGHT PLAYER_2

# Menu navigation
CONTROLLER_BUTTON_UP CONTROLLER_1 BUTTON_UP PLAYER_1
CONTROLLER_BUTTON_DOWN CONTROLLER_1 BUTTON_DOWN PLAYER_1

# Enter / select
CONTROLLER_BUTTON_RIGHT CONTROLLER_1 BUTTON_1 PLAYER_1

# Gun analogue controls - player 1
CONTROLLER_ANALOGUE_X CONTROLLER_1 ANALOGUE_1 REVERSE
CONTROLLER_ANALOGUE_Y CONTROLLER_1 ANALOGUE_2

# Gun analogue controls - player 2
CONTROLLER_ANALOGUE_X CONTROLLER_2 ANALOGUE_3 REVERSE
CONTROLLER_ANALOGUE_Y CONTROLLER_2 ANALOGUE_4
