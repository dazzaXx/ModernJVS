# ModernJVS Config
# Author: Bobby Dilley, ModernJVS Contributors

# Setup the default game to emulate
# Use ROTARY for the rotary controller on the HAT
DEFAULT_GAME generic-driving

# Setup which IO to emulate by default
EMULATE namco-FCA1

# Setup the sense line
# SENSE_LINE_TYPE 0 - USB to RS485 with no sense line
# SENSE_LINE_TYPE 1 - USB to RS485 with sense line
SENSE_LINE_TYPE 1
SENSE_LINE_PIN 26

# Setup the debug mode for outputting debug information
# DEBUG_MODE 1 - This will show the JVS outputs
# DEBUG_MODE 2 - This will show the raw packet outputs
DEBUG_MODE 0

# Setup the device path
DEVICE_PATH /dev/ttyUSB0

# Automatic Controller Detection
# If set to 0 ModernJVS will ignore all controllers
# that haven't already been mapped.
AUTO_CONTROLLER_DETECTION 1

# Analog Deadzone for Controller Analog Sticks (X and Y axes)
# Value range: 0.0 to 0.5 (0.0 = no deadzone, 0.1 = 10% deadzone, etc.)
# Each player can have a different deadzone value configured independently.
# This only applies to analog stick inputs (X and Y axes).
# Does not affect guns, rotary controllers, or other input types.
# Examples:
#   ANALOG_DEADZONE_PLAYER_1 0.1   # Player 1 has 10% deadzone
#   ANALOG_DEADZONE_PLAYER_2 0.15  # Player 2 has 15% deadzone
#   ANALOG_DEADZONE_PLAYER_3 0.05  # Player 3 has 5% deadzone
#   ANALOG_DEADZONE_PLAYER_4 0.0   # Player 4 has no deadzone
ANALOG_DEADZONE_PLAYER_1 0.2
ANALOG_DEADZONE_PLAYER_2 0.2
ANALOG_DEADZONE_PLAYER_3 0.2
ANALOG_DEADZONE_PLAYER_4 0.2

# Wii Remote IR Border
# Extends the valid IR range beyond the nominal screen edges before triggering
# the "screen out" state. When pointing near or slightly past the edge of the
# screen, this prevents the cursor disappearing prematurely.
# Coordinates within the border are clamped to the nearest screen edge [0, 1].
# Value range: 0.0 to 0.5 (0.0 = strict screen boundary, 0.1 = 10% extension)
# Default is 0.0 (no extension). Increase if shooting near the screen edge
# causes the gun to go "out of bounds" too early.
WII_IR_BORDER 0.0

# Wii Remote IR Scale
# Scales the IR coordinate space around the centre of the screen, allowing you
# to aim the Wiimote to more extreme angles before the cursor goes off-screen.
# Values > 1.0 expand the required physical aiming range (aim further before
# going off-screen). Values < 1.0 make the aiming more sensitive.
# Example: WII_IR_SCALE 1.3 means you need to aim ~30% further in any direction
# before the cursor reaches the screen edge.
# Value range: 0.1 to 5.0 (1.0 = no scaling, default)
WII_IR_SCALE 1.0
